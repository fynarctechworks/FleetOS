{
  "expo": {
    "name": "FleetOS",
    "slug": "fleetos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fleetos",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1A3C6E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fleetos.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FleetOS needs your location to track fleet vehicles.",
        "NSLocationAlwaysUsageDescription": "FleetOS needs your location in the background to track fleet vehicles.",
        "NSCameraUsageDescription": "FleetOS needs camera access to capture delivery proof photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3C6E"
      },
      "package": "com.fleetos.mobile",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "21ced314-f503-4745-9cce-80b7c48364d2"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "fleetos.infynarc"
  }
}
