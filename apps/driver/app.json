{
  "expo": {
    "name": "FleetOS Driver",
    "slug": "fleetos-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fleetos-driver",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1A3C6E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fleetos.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FleetOS needs your location to update trip status.",
        "NSLocationAlwaysUsageDescription": "FleetOS needs your location in the background to track your trip route.",
        "NSCameraUsageDescription": "FleetOS needs camera access to capture delivery proof photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3C6E"
      },
      "package": "com.fleetos.driver",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "5fb447ed-0fde-4836-93a0-2871bd81299f"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "fleetos.infynarc"
  }
}
